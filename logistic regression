# Different C value vs their corresponding F1-score, Accuracy, and Log-loss for Logistic Regression
C_values = [0.01, 0.1, 1, 10, 100]

f1_high, f1_medium, f1_low = [], [], []
accuracy_list, logloss_list = [], []

for C in C_values:
    pipe = Pipeline([
        ("scaler", StandardScaler()),
        ("model", LogisticRegression(solver="lbfgs", max_iter=1000))
    ])
    pipe.set_params(model__C=C)
    pipe.fit(X_train, y_train)
    
    y_pred = pipe.predict(X_test)
    y_prob = pipe.predict_proba(X_test)
    
    # F1-score per class
    report = classification_report(y_test, y_pred, output_dict=True)
    f1_high.append(report.get("High", {}).get("f1-score", 0))
    f1_medium.append(report.get("Medium", {}).get("f1-score", 0))
    f1_low.append(report.get("Low", {}).get("f1-score", 0))
    
    # Accuracy
    accuracy_list.append(accuracy_score(y_test, y_pred))
    
    # Log-loss
    logloss_list.append(log_loss(y_test, y_prob))

# Draw
fig, ax1 = plt.subplots(figsize=(10,6))

# F1-score per class
line1, = ax1.plot(C_values, f1_high, label="F1-High", marker='o', linewidth=2)
line2, = ax1.plot(C_values, f1_medium, label="F1-Medium", marker='s', linewidth=2)
line3, = ax1.plot(C_values, f1_low, label="F1-Low", marker='^', linewidth=2)

# Accuracy
line4, = ax1.plot(C_values, accuracy_list, label="Accuracy", marker='D', linewidth=2, linestyle='--')

ax1.set_xscale('log')
ax1.set_xlabel("C value (log scale)")
ax1.set_ylabel("F1-score / Accuracy")
ax1.set_title("Classification Performance vs C value")
ax1.grid(True, linestyle='--', alpha=0.6)

# Log-loss 
ax2 = ax1.twinx()
line5, = ax2.plot(C_values, logloss_list, label="Log-loss", marker='x', linewidth=2, linestyle=':', color='red')
ax2.set_ylabel("Log-loss", color='red')
ax2.tick_params(axis='y', labelcolor='red')

# labels Display
lines = [line1, line2, line3, line4, line5]
